# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/

# Virtual env & secrets
.venv/
venv/
.env
.env.*
!.env.example

# Build / packaging
dist/
build/
*.egg
wheelhouse/

# Coverage / tests
.coverage
.coverage.*
htmlcov/
coverage.xml
pytestdebug.log

# --- Repo-root runtime (not source code) ---
# Use /memory/ (leading slash) only: a bare "memory/" would ignore src/sage/memory/
# (the package). Root memory/ is session state — do not commit.
/memory/
/datasets/
bench*.json
*_out.json
*.log

# Local scratch & trees (repo root)
bench_out.txt
simialr stuff/

# Editable install
src/*.egg-info/
*.egg-info/

# Planning drafts (optional)
plan v1/
plan v2/
plan final/
sage plan/

.spec_staging/

# Local chat transcripts (rules under .sage/ may still be committed)
.sage/chat_sessions/

# IDE
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Track docs/
!docs/

images/